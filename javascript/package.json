{
  "name": "quorlen",
  "version": "1.1.0",
  "description": "A lightweight, zero-dependency NLP engine that estimates how important or meaningful a piece of text is.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc && node -e \"const fs = require('fs'); fs.copyFileSync('src/dictionary.json', 'dist/dictionary.json');\"",
    "start": "ts-node example.ts",
    "test": "ts-node example.ts",
    "prepublishOnly": "npm run build"
  },
  "author": "Muthana ALMaiah",
  "license": "MIT",
  "keywords": [
    "text-significance",
    "text-importance",
    "meaningful-text",
    "semantic-importance",
    "information-value",
    "text-ranking",
    "nlp",
    "typescript",
    "javascript",
    "ai",
    "llm",
    "rag-filtering",
    "llm-workflows",
    "summarization",
    "content-filtering",
    "natural-language-processing",
    "semantic-analysis",
    "text-analysis",
    "lexicon",
    "deterministic",
    "zero-dependency"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/5bbvm/Quorlen.git",
    "directory": "javascript"
  },
  "bugs": {
    "url": "https://github.com/5bbvm/Quorlen/issues"
  },
  "homepage": "https://github.com/5bbvm/Quorlen#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}